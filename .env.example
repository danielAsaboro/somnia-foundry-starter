# Somnia official network values from docs.somnia.network as of 2026-05-19
SOMNIA_RPC_MAINNET=https://api.infra.mainnet.somnia.network/
SOMNIA_RPC_TESTNET=https://dream-rpc.somnia.network/
SOMNIA_WS_MAINNET=wss://api.infra.mainnet.somnia.network/ws
SOMNIA_WS_TESTNET=wss://dream-rpc.somnia.network/ws

SOMNIA_MAINNET_CHAIN_ID=5031
SOMNIA_TESTNET_CHAIN_ID=50312

# Fill these locally before deploy/broadcast actions.
PRIVATE_KEY=
DEPLOYER_ADDRESS=

# Somnia Agent platform contract address (Shannon testnet).
# Source: https://docs.somnia.network/agents/invoking-agents/from-solidity
SOMNIA_AGENT_PLATFORM=0x037Bb9C718F3f7fe5eCBDB0b600D607b52706776

# Set after deploying AgentExample.
AGENT_EXAMPLE_ADDRESS=

# Optional for reproducible fork tests.
FORK_BLOCK_MAINNET=
